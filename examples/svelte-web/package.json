{
  "name": "sauron-svelte-web-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-page Vite + Svelte 5 demo that showcases the @sauron/browser SDK end-to-end.",
  "scripts": {
