{
  "name": "@sauron/browser",
  "version": "0.2.0",
  "description": "Sauron browser SDK: automatic error reporting + product analytics for the web.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "sauron",
    "error-tracking",
    "analytics",
    "observability",
    "monitoring",
    "sdk",
    "browser"
  ],
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "access": "public"
  }
}
