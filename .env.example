# Copy to `.env` and adjust. Used by docker-compose.yml.

# --- Postgres ---
POSTGRES_USER=sauron
POSTGRES_PASSWORD=sauron
POSTGRES_DB=sauron

# --- Auth ---
# CHANGE THIS. Any long random string; the API refuses to start without it in compose.
JWT_SECRET=change-me-to-a-long-random-secret-000000000000

# --- CORS / URLs ---
# Origin the dashboard is served from (used for API CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# API base URL as seen from the user's BROWSER (host-published port, not the compose network).
API_BASE_URL=http://localhost:8080

# --- Logging ---
RUST_LOG=info,sauron=debug
