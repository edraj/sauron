# Copy to `.env` and adjust. Used by docker-compose.yml.

# --- Postgres ---
POSTGRES_USER=sauron
POSTGRES_PASSWORD=sauron
POSTGRES_DB=sauron

# --- Auth ---
# CHANGE THIS. Any long random string; the API refuses to start without it in compose.
JWT_SECRET=change-me-to-a-long-random-secret-000000000000

# --- CORS / URLs ---
# Origin the dashboard is served from (used for API CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# API base URL as seen from the user's BROWSER (host-published port, not the compose network).
API_BASE_URL=http://localhost:8080

# --- Logging ---
RUST_LOG=info,sauron=debug

# --- uptime monitor (sauron-monitor) ---
MONITOR_TICK_MS=1000
MONITOR_BATCH=100
MONITOR_MAX_CONCURRENCY=50
MONITOR_CHECK_RETENTION_DAYS=30
# Set true only for internal self-monitoring of private addresses.
MONITOR_SSRF_ALLOW_PRIVATE=false

# --- hot/cold tiering (sauron-tier) ---
TIER_HOT_DAYS=30
TIER_GRANULARITY=day
TIER_DROP_LAG_HOURS=24
TIER_TICK_SECS=3600
TIER_PARTITION_AHEAD=7
# Cold-storage path is a FIXED in-container path set by docker-compose (/cold);
# not read from this env file. Shown here for reference.
# TIER_COLD_PATH=/cold
